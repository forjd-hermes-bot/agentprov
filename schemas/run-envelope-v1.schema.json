{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentProv Run Envelope v1",
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "trace_id",
    "trigger",
    "agent",
    "actor_chain",
    "runtime",
    "authority",
    "started_at",
    "status"
  ],
  "properties": {
    "schema": {
      "const": "agentprov.dev/run-envelope/v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "trigger": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "enum": [
            "manual",
            "scheduled",
            "webhook",
            "api",
            "ci",
            "delegated"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "agent": {
      "type": "object",
      "required": [
        "agent_id",
        "version",
        "manifest_digest"
      ],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "manifest_digest": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "actor_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "id"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "auth_method": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "runtime": {
      "type": "object",
      "required": [
        "host",
        "os",
        "environment"
      ],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "os": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "container_image_digest": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "authority": {
      "type": "object",
      "required": [
        "capabilities",
        "policy_id",
        "policy_version"
      ],
      "properties": {
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "started_at": {
      "type": "string"
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
