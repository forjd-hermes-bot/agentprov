{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentProv Policy v1",
  "type": "object",
  "required": [
    "schema",
    "policy_id",
    "version",
    "agent_id"
  ],
  "properties": {
    "schema": {
      "const": "agentprov.dev/policy/v1"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "allow": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "deny": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "require_approval": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": [
        "action",
        "resource"
      ],
      "properties": {
        "action": {
          "type": "string",
          "minLength": 1
        },
        "resource": {
          "type": "string",
          "minLength": 1
        },
        "expires_at": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
