{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentProv Provenance Event v1",
  "type": "object",
  "required": [
    "schema",
    "event_id",
    "run_id",
    "sequence",
    "timestamp",
    "event_type",
    "subject",
    "previous_event_hash",
    "event_hash"
  ],
  "properties": {
    "schema": {
      "const": "agentprov.dev/event/v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "timestamp": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "action": {
      "type": [
        "string",
        "null"
      ]
    },
    "resource": {
      "type": [
        "string",
        "null"
      ]
    },
    "payload_digest": {
      "type": [
        "string",
        "null"
      ]
    },
    "previous_event_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "event_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "signature": {
      "type": [
        "object",
        "null"
      ]
    },
    "key_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {}
  },
  "additionalProperties": true
}
